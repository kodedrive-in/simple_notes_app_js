<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Note | My Notes</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-slate-950 text-white">

  <div class="min-h-screen px-6 py-10">

    <!-- Back -->
    <div class="max-w-4xl mx-auto">
      <a href="/" class="inline-flex items-center gap-2 text-indigo-400 hover:text-indigo-300 transition">
        ← Back to Notes
      </a>
    </div>

    <!-- Edit Card -->
    <div class="max-w-4xl mx-auto mt-6">

      <div class="bg-slate-900 border border-slate-800 rounded-3xl shadow-2xl p-8">

        <!-- Icon -->
        <div class="w-14 h-14 rounded-2xl bg-amber-500 flex items-center justify-center text-3xl mb-6">
          ✏️
        </div>

        <h1 class="text-4xl font-bold tracking-tight mb-8">
          Edit Note
        </h1>

        <form action="/edit" method="POST">

          <!-- Hidden old filename -->
          <input type="hidden" name="previous" value="<%= filename %>">

          <!-- Note Title -->
          <label class="block text-slate-300 mb-2">
            Note Title
          </label>

          <input type="text" name="new" value="<%= filename.replace('.txt','') %>"
            class="w-full bg-slate-800 border border-slate-700 rounded-xl px-5 py-3 outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/30 transition">

          <!-- Note Content -->
          <label class="block text-slate-300 mt-6 mb-2">
            Note Content
          </label>

          <textarea name="details"
            class="w-full h-72 bg-slate-800 border border-slate-700 rounded-xl px-5 py-3 outline-none resize-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/30 transition whitespace-pre-wrap"><%= filedata %></textarea>

          <!-- Button -->
          <button type="submit"
            class="mt-8 w-full bg-amber-500 hover:bg-amber-600 text-slate-950 font-semibold rounded-xl py-3 transition">
            💾 Save Changes
          </button>

        </form>

      </div>

    </div>

  </div>

</body>

</html>