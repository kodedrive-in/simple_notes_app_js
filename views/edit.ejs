<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Edit Task</title>
    <script src="https://cdn.tailwindcss.com"></script>
  </head>

  <body>
    <div class="w-full min-h-screen bg-zinc-900 text-white p-10">
      <a href="/" class="text-blue-500"> ← Back </a>

      <h1 class="text-4xl mt-6 mb-6">Edit Task</h1>

      <form action="/edit" method="POST">
        <!-- old filename -->
        <input type="hidden" name="previous" value="<%= filename %>" />

        <!-- editable filename -->
        <input
          class="block w-1/2 bg-zinc-800 rounded px-4 py-2"
          type="text"
          name="new"
          value="<%= filename.replace('.txt','') %>"
        />

        <!-- editable body -->
        <textarea
          class="block w-1/2 h-56 bg-zinc-800 rounded px-4 py-2 mt-4"
          name="details"
        >
<%= filedata %></textarea
        >

        <input
          class="mt-4 bg-yellow-600 px-6 py-2 rounded cursor-pointer"
          type="submit"
          value="Update Task"
        />
      </form>
    </div>
  </body>
</html>