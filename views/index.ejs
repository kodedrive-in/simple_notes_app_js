<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Notes</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-slate-950 text-white">

    <div class="min-h-screen">

        <!-- Header -->
        <div class="text-center pt-14">
            <h1 class="text-6xl font-extrabold tracking-tight">
                My Notes
            </h1>

            <p class="text-slate-400 mt-3 text-lg">
                Capture your ideas, thoughts and reminders.
            </p>
        </div>

        <!-- Create Note -->
        <div class="max-w-4xl mx-auto mt-12 px-6">

            <div class="bg-slate-900 border border-slate-800 rounded-3xl shadow-2xl p-8">

                <h2 class="text-2xl font-semibold mb-6">
                    Create a New Note
                </h2>

                <form action="/create" method="POST">

                    <input type="text" name="title" placeholder="Note title..."
                        class="w-full bg-slate-800 border border-slate-700 rounded-xl px-5 py-3 outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/30 transition">

                    <textarea name="details" placeholder="Write your note here..."
                        class="w-full h-40 mt-5 bg-slate-800 border border-slate-700 rounded-xl px-5 py-3 outline-none resize-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/30 transition"></textarea>

                    <button type="submit"
                        class="mt-6 w-full bg-indigo-600 hover:bg-indigo-700 rounded-xl py-3 text-lg font-semibold transition">
                        📝 Save Note
                    </button>

                </form>

            </div>

        </div>

        <!-- Notes -->
        <div class="max-w-7xl mx-auto mt-16 px-6 pb-12">

            <div class="flex items-center justify-between mb-8">

                <h2 class="text-3xl font-semibold">
                    Recent Notes
                </h2>

                <span class="text-slate-500 text-sm">
                    <%= files.length %> Notes
                </span>

            </div>

            <% if(files.length> 0){ %>

                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-7">

                    <% files.forEach(function(val){ %>

                        <div
                            class="bg-slate-900 border border-slate-800 rounded-2xl p-6 hover:border-indigo-500 hover:shadow-xl hover:shadow-indigo-900/20 hover:-translate-y-1 transition duration-300">

                            <!-- Note Icon -->
                            <div
                                class="w-12 h-12 rounded-xl bg-indigo-600 flex items-center justify-center text-2xl mb-5">
                                📝
                            </div>

                            <!-- Note Title -->
                            <h3 class="text-2xl font-bold break-words">
                                <%= val.replace(".txt","") %>
                            </h3>

                            <div class="h-px bg-slate-800 my-5"></div>

                            <!-- Actions -->
                            <div class="flex justify-between items-start">

                                <a href="/files/<%= val %>"
                                    class="text-indigo-400 hover:text-indigo-300 font-medium transition">
                                    Open
                                </a>

                                <div class="flex flex-col items-end gap-2">

                                    <form action="/delete" method="POST">

                                        <input type="hidden" name="filename" value="<%= val %>">

                                        <button type="submit" class="text-rose-500 hover:text-rose-400 transition">
                                            Delete
                                        </button>

                                    </form>
                                    <a href="/edit/<%= val %>" class="text-amber-400 hover:text-amber-300 transition">
                                        Edit
                                    </a>

                                </div>

                            </div>

                        </div>

                        <% }) %>

                </div>

                <% } else { %>

                    <div class="bg-slate-900 border border-dashed border-slate-700 rounded-3xl py-20 text-center">

                        <div class="text-7xl mb-5">
                            📒
                        </div>

                        <h2 class="text-3xl font-semibold">
                            No Notes Yet
                        </h2>

                        <p class="text-slate-400 mt-3">
                            Start writing your first note and keep your ideas organized.
                        </p>

                    </div>

                    <% } %>

        </div>

    </div>

</body>

</html>