<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Task Manager</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body>
    <div class="main w-full min-h-screen bg-zinc-900">

        <!-- Create Task Form -->
        <div class="form p-10 text-white">
            <form action="/create" method="POST">

                <input class="block w-full rounded-md outline-none px-5 py-2 text-black" type="text" name="title"
                    placeholder="Title goes here...">

                <textarea class="block w-full h-32 rounded-md outline-none px-5 py-2 mt-2 text-black"
                    name="details" placeholder="Write your task details here..."></textarea>

                <input class="mt-2 bg-blue-600 px-5 py-2 rounded-md cursor-pointer" type="submit" value="Create Task">

            </form>
        </div>

        <!-- Tasks -->
        <div class="tasks flex gap-3 flex-wrap p-10">

            <% if (files.length> 0) { %>

                <% files.forEach(function(val) { %>

                    <div class="task w-72 px-3 py-4 rounded-md bg-zinc-800">

                        <h1 class="text-white text-3xl tracking-tighter break-words">
                            <%= val %>
                        </h1>

                        <div class="flex justify-between mt-4">

                            <!-- Open -->
                            <a class="text-blue-500 hover:text-blue-400" href="/files/<%= val %>">
                                Open
                            </a>

                            <!-- Delete & Edit -->
                            <div class="flex flex-col items-end gap-1">

                                <form action="/delete" method="POST">
                                    <input type="hidden" name="filename" value="<%= val %>">

                                    <button type="submit" class="text-red-500 hover:text-red-400">
                                        Delete
                                    </button>
                                </form>

                                <a class="text-zinc-400 hover:text-zinc-200" href="/edit/<%= val %>">
                                    Edit
                                </a>

                            </div>

                        </div>

                    </div>

                    <% }) %>

                        <% } else { %>

                            <h3 class="text-zinc-600 text-2xl">
                                No tasks yet
                            </h3>

                            <% } %>

        </div>

    </div>
</body>

</html>
